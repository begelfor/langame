# Copy this file to .env and adjust values for your machine.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the app (Expo convention).

# Backend API base URL the app talks to.
# - Web / iOS simulator:        http://127.0.0.1:8000/api/v1
# - Android emulator (AVD):     http://10.0.2.2:8000/api/v1
# - Physical device on LAN:     http://<your-mac-lan-ip>:8000/api/v1
#   (find it with: ipconfig getifaddr en0)
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Copy to .env and adjust for your local environment.
# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres runs in Docker on host port 5433 to avoid conflicts; app runs on host)
DATABASE_URL=postgres://langame:langame@localhost:5433/langame

# Celery / Redis (Redis runs in Docker on host port 6380 to avoid conflicts; app runs on host)
REDIS_URL=redis://localhost:6380/0
